// user-service.test.js
const { createUser } = require('./user-service');

jest.mock('./db');
jest.mock('./email');

const db = require('./db');
const emailService = require('./email');

describe('User Service', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  it('should create user and send welcome email', async () => {
    const mockUser = { id: 1, email: 'test@example.com' };
    db.users.insert.mockResolvedValue(mockUser);
    emailService.sendWelcome.mockResolvedValue(true);

    const result = await createUser({ email: 'test@example.com' });

    expect(result).toEqual(mockUser);
    expect(db.users.insert).toHaveBeenCalledWith({ email: 'test@example.com' });
    expect(emailService.sendWelcome).toHaveBeenCalledWith('test@example.com');
  });

  it('should throw error if database fails', async () => {
    db.users.insert.mockRejectedValue(new Error('DB error'));

    await expect(createUser({ email: 'test@example.com' }))
      .rejects.toThrow('DB error');
    expect(emailService.sendWelcome).not.toHaveBeenCalled();
  });
});
