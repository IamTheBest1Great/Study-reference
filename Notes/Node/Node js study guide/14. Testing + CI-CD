### Integration Testing with Supertest

```javascript
// app.js
const express = require('express');
const app = express();

app.use(express.json());

app.get('/health', (req, res) => {
  res.json({ status: 'ok' });
});

app.post('/users', async (req, res) => {
  const { name, email } = req.body;
  if (!name || !email) {
    return res.status(400).json({ error: 'Name and email required' });
  }
  // In real app: save to database
  res.status(201).json({ id: '123', name, email });
});

app.get('/users/:id', async (req, res) => {
  const { id } = req.params;
  // In real app: fetch from database
  if (id === '999') {
    return res.status(404).json({ error: 'User not found' });
  }
  res.json({ id, name: 'Test User', email: 'test@example.com' });
});

module.exports = app;
```

```javascript
// app.test.js
const request = require('supertest');
const app = require('./app');

describe('API Endpoints', () => {
  describe('GET /health', () => {
    it('should return status ok', async () => {
      const response = await request(app)
        .get('/health')
        .expect('Content-Type', /json/)
        .expect(200);

      expect(response.body).toEqual({ status: 'ok' });
    });
  });

  describe('POST /users', () => {
    it('should create a new user', async () => {
      const response = await request(app)
        .post('/users')
        .send({ name: 'Alice', email: 'alice@example.com' })
        .expect(201);

      expect(response.body).toMatchObject({
        name: 'Alice',
        email: 'alice@example.com'
      });
      expect(response.body.id).toBeDefined();
    });

    it('should return 400 if name missing', async () => {
      const response = await request(app)
        .post('/users')
        .send({ email: 'alice@example.com' })
        .expect(400);

      expect(response.body.error).toContain('Name');
    });
  });

  describe('GET /users/:id', () => {
    it('should return user by id', async () => {
      const response = await request(app)
        .get('/users/123')
        .expect(200);

      expect(response.body).toMatchObject({ id: '123', name: 'Test User' });
    });

    it('should return 404 if user not found', async () => {
      await request(app)
        .get('/users/999')
        .expect(404);
    });
  });
});
```

### Testing with Real Database (Testcontainers)

```javascript
const { PostgreSqlContainer } = require('@testcontainers/postgresql');
const { Client } = require('pg');
const app = require('./app');

describe('API with real database', () => {
  let container;
  let client;
  let server;

  beforeAll(async () => {
    container = await new PostgreSqlContainer()
      .withDatabase('testdb')
      .withUsername('testuser')
      .withPassword('testpass')
      .start();

    client = new Client({
      host: container.getHost(),
      port: container.getPort(),
      database: container.getDatabase(),
      user: container.getUsername(),
      password: container.getPassword()
    });
    await client.connect();

    // Run migrations
    await client.query(`
      CREATE TABLE users (
        id SERIAL PRIMARY KEY,
        name VARCHAR(255),
        email VARCHAR(255) UNIQUE
      )
    `);

    // Pass db client to app
    app.set('db', client);
    server = app.listen(0);
  }, 30000);

  afterAll(async () => {
    await client.end();
    await container.stop();
    server.close();
  });

  it('should create and retrieve user', async () => {
    const port = server.address().port;
    const createRes = await request(`http://localhost:${port}`)
      .post('/users')
      .send({ name: 'Bob', email: 'bob@example.com' });

    const userId = createRes.body.id;

    const getRes = await request(`http://localhost:${port}`)
      .get(`/users/${userId}`);

    expect(getRes.body.name).toBe('Bob');
  });
});
```

