### Canary Analyzer Script

```javascript
// scripts/canary-analyzer.js
const fetch = require('node-fetch');

const PROMETHEUS_URL = process.env.PROMETHEUS_URL;
const CANARY_VERSION = process.env.CANARY_VERSION;
const ERROR_THRESHOLD = 0.01; // 1% error rate
const LATENCY_THRESHOLD = 500; // 500ms p95

async function queryPrometheus(query) {
  const url = `${PROMETHEUS_URL}/api/v1/query?query=${encodeURIComponent(query)}`;
  const res = await fetch(url);
  const data = await res.json();
  return parseFloat(data.data.result[0]?.value[1]) || 0;
}

async function analyze() {
  const errorRate = await queryPrometheus(`
    sum(rate(http_requests_total{version="${CANARY_VERSION}",status=~"5.."}[5m]))
    /
    sum(rate(http_requests_total{version="${CANARY_VERSION}"}[5m]))
  `);

  const p95Latency = await queryPrometheus(`
    histogram_quantile(0.95,
      sum(rate(http_request_duration_seconds_bucket{version="${CANARY_VERSION}"}[5m]))
      by (le)
    )
  `) * 1000;

  console.log(`Error Rate: ${(errorRate * 100).toFixed(2)}%`);
  console.log(`P95 Latency: ${p95Latency.toFixed(2)}ms`);

  if (errorRate > ERROR_THRESHOLD) {
    console.error('❌ Error rate too high! Rolling back...');
    process.exit(1);
  }

  if (p95Latency > LATENCY_THRESHOLD) {
    console.error('❌ Latency too high! Rolling back...');
    process.exit(1);
  }

  console.log('✅ Canary metrics healthy. Promoting...');
}

analyze().catch(err => {
  console.error(err);
  process.exit(1);
});
```

