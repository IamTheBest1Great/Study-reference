### Self‑Hosted Feature Flags with Redis

```javascript
class FeatureFlagService {
  constructor(redis) {
    this.redis = redis;
    this.cache = new Map();
    this.cacheTTL = 60000; // 1 minute
  }

  async isEnabled(flagKey, userId = null, defaultValue = false) {
    const cacheKey = `${flagKey}:${userId || 'global'}`;
    const cached = this.cache.get(cacheKey);
    if (cached && Date.now() < cached.expires) {
      return cached.value;
    }

    // Check user‑specific override
    if (userId) {
      const userOverride = await this.redis.get(`flag:${flagKey}:user:${userId}`);
      if (userOverride !== null) {
        const value = userOverride === 'true';
        this.cache.set(cacheKey, { value, expires: Date.now() + this.cacheTTL });
        return value;
      }
    }

    // Check global flag
    const globalFlag = await this.redis.get(`flag:${flagKey}:global`);
    const value = globalFlag !== null ? globalFlag === 'true' : defaultValue;

    this.cache.set(cacheKey, { value, expires: Date.now() + this.cacheTTL });
    return value;
  }

  async setFlag(flagKey, enabled, userId = null) {
    const key = userId ? `flag:${flagKey}:user:${userId}` : `flag:${flagKey}:global`;
    await this.redis.set(key, enabled.toString());
    this.cache.clear(); // Invalidate cache
  }

  async setPercentageRollout(flagKey, percentage) {
    await this.redis.set(`flag:${flagKey}:percentage`, percentage.toString());
  }

  async isEnabledWithRollout(flagKey, userId) {
    const percentage = await this.redis.get(`flag:${flagKey}:percentage`);
    if (!percentage) return this.isEnabled(flagKey, userId);

    // Deterministic hash for consistent rollout
    const hash = crypto.createHash('md5').update(`${flagKey}:${userId}`).digest('hex');
    const bucket = parseInt(hash.substring(0, 8), 16) % 100;
    return bucket < parseInt(percentage);
  }
}
```

### Feature Flags in Frontend (React)

```javascript
// FeatureFlagContext.jsx
import React, { createContext, useContext, useEffect, useState } from 'react';
import * as LDClient from 'launchdarkly-js-client-sdk';

const FeatureFlagContext = createContext({});

export function FeatureFlagProvider({ children, user }) {
  const [flags, setFlags] = useState({});
  const [client, setClient] = useState(null);

  useEffect(() => {
    const ldClient = LDClient.initialize(process.env.REACT_APP_LD_CLIENT_KEY, {
      key: user.id,
      email: user.email,
      custom: { plan: user.plan }
    });

    ldClient.on('ready', () => {
      setFlags(ldClient.allFlags());
    });

    ldClient.on('change', (changes) => {
      setFlags(prev => ({ ...prev, ...changes }));
    });

    setClient(ldClient);

    return () => ldClient.close();
  }, [user]);

  return (
    <FeatureFlagContext.Provider value={{ flags, client }}>
      {children}
    </FeatureFlagContext.Provider>
  );
}

export function useFeatureFlag(flagKey, defaultValue = false) {
  const { flags } = useContext(FeatureFlagContext);
  return flags[flagKey] ?? defaultValue;
}

// Usage in component
function Dashboard() {
  const showNewUI = useFeatureFlag('new-dashboard');
  return showNewUI ? <NewDashboard /> : <OldDashboard />;
}
```

### Best Practices for Feature Flags

1. **Naming convention**: Use descriptive names with prefixes (`release/`, `experiment/`, `ops/`)
2. **Default to safe values**: Ensure app works with flags off
3. **Clean up stale flags**: Remove flag code after full rollout
4. **Monitor flag usage**: Track evaluation metrics
5. **Use short‑lived flags**: Avoid permanent flags that become technical debt
6. **Test with flags on/off**: Include flag variations in test suite

